{
  "manifest_version": 3,
  "name": "Agente UAM",
  "version": "1.0",
  "description": "Unidad Automatizada de Monitoreo de Navegación",
  "permissions": [
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "http://192.168.1.66:8080/*", 
    "http://localhost:8080/*",
    "http://100.75.11.59:8080/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}